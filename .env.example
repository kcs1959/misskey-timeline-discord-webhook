# Misskey instance URL (no trailing slash)
MISSKEY_ORIGIN=https://misskey.example.com

# API token (required for homeTimeline / hybridTimeline)
MISSKEY_TOKEN=

# Discord incoming webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Timeline channel: localTimeline | globalTimeline | homeTimeline | hybridTimeline
TIMELINE=localTimeline

# Include renotes and replies in the Misskey stream
WITH_RENOTES=true
WITH_REPLIES=true

# Subscribe only to notes with attached files (Misskey's official withFiles)
WITH_FILES=false

# Include attached files (embeds / links) in Discord messages
INCLUDE_ATTACHMENTS=true

# Forward CW / NSFW / reply notes to Discord (see README for details)
FORWARD_CW=true
FORWARD_NSFW=false
FORWARD_REPLIES=true

# Reliability tuning
DEDUP_MAX=1000
DISCORD_QUEUE_MAX=500
DISCORD_SEND_INTERVAL_MS=2000
